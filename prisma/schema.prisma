generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum CreditTxType {
  AWARD       // Vergabe von Credits
  ADJUSTMENT  // Admin-Korrektur (+/-)
}

enum Role {
  USER
  ADMIN
}

enum CreditTxReason {
  TRAINING_CLAIM
  ADMIN_ADJUST
  CERTIFICATE_ISSUED
}

enum EnrollmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  ATTENDED
  NO_SHOW
  COMPLETED
  CERTIFICATE_ISSUED
}

enum CertificateStatus {
  ISSUED
  REVOKED
}

enum CertificateKind {
  ATTENDANCE_CONFIRMATION
  CERTIFICATE
  VDI_CERTIFICATE
}

model User {
  id           String @id @default(cuid())
  email        String @unique
  passwordHash String

  // Persönliche Daten
  name      String?
  firstName String?
  lastName  String?
  birthDate DateTime?
  gender    String?
  phone     String?

  // Firmendaten
  company        String?
  companyAddress String?
  companyStreet  String?
  companyZip     String?
  companyCity    String?
  companyCountry String?
  position       String?

  role         Role @default(USER)
  creditsTotal Int  @default(0)

  creditTxs    CreditTransaction[]
  enrollments  Enrollment[]
  certificates Certificate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Training {
  id    String @id @default(cuid())
  title String

  // Kürzel aus Cobra oder manuell für Übergangszeit
  // Beispiele: A1, A2, B, C, DOK, BETR, SICH, SER-SWB
  code String?

  // Startdatum der Schulung
  date DateTime

  // Detailfelder für Schulungen / spätere Cobra-Daten
  endDate     DateTime?
  location    String?
  instructor  String?
  description String?

  // Dokumentart für spätere Zertifikats-/Teilnahmebestätigungslogik
  certificateKind CertificateKind?

  // Optionaler späterer Cobra-Bezug
  cobraId String? @unique

  // Credits werden erst bei Zertifikatserstellung vergeben
  creditsAward Int @default(0)

  tokens       ClaimToken[]
  creditTxs    CreditTransaction[]
  enrollments  Enrollment[]
  certificates Certificate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@index([certificateKind])
}

model Enrollment {
  id         String @id @default(cuid())
  userId     String
  trainingId String

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  training Training @relation(fields: [trainingId], references: [id], onDelete: Cascade)

  status   EnrollmentStatus @default(CONFIRMED)
  attended Boolean          @default(false)
  passed   Boolean          @default(false)

  certificate Certificate?

  registeredAt DateTime @default(now())
  completedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, trainingId])
  @@index([trainingId, status])
  @@index([userId, status])
}

model Certificate {
  id           String @id @default(cuid())
  userId       String
  trainingId   String
  enrollmentId String @unique

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  training   Training   @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  title    String
  issuedAt DateTime          @default(now())
  status   CertificateStatus @default(ISSUED)
  credits  Int               @default(0)

  // Wird bei Erstellung aus Training übernommen, damit das Zertifikat historisch stabil bleibt
  code            String?
  certificateKind CertificateKind?

  pdfUrl String?
  note   String?

  creditTx CreditTransaction?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, issuedAt])
  @@index([trainingId, issuedAt])
  @@index([code])
  @@index([certificateKind])
}

model ClaimToken {
  id         String   @id @default(cuid())
  token      String   @unique
  trainingId String
  training   Training @relation(fields: [trainingId], references: [id], onDelete: Cascade)

  expiresAt DateTime
  maxClaims Int @default(999999)
  claims    Int @default(0)

  creditTxs CreditTransaction[]

  createdAt DateTime @default(now())
}

model CreditTransaction {
  id     String @id @default(cuid())
  userId String
  amount Int
  type   CreditTxType
  reason CreditTxReason

  trainingId    String?
  certificateId String? @unique
  claimTokenId  String?

  meta Json?

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  training    Training?    @relation(fields: [trainingId], references: [id], onDelete: SetNull)
  certificate Certificate? @relation(fields: [certificateId], references: [id], onDelete: SetNull)
  claimToken  ClaimToken?  @relation(fields: [claimTokenId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([trainingId, createdAt])
  @@index([claimTokenId, createdAt])
  @@index([certificateId, createdAt])
}