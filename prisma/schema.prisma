generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum CreditTxType {
  AWARD
  ADJUSTMENT
}

enum Role {
  USER
  ADMIN
}

enum CreditTxReason {
  TRAINING_CLAIM
  ADMIN_ADJUST
  CERTIFICATE_ISSUED
}

enum EnrollmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  ATTENDED
  NO_SHOW
  COMPLETED
  CERTIFICATE_ISSUED
}

enum CertificateStatus {
  ISSUED
  REVOKED
}

enum CertificateKind {
  ATTENDANCE_CONFIRMATION
  CERTIFICATE
  VDI_CERTIFICATE
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([userId])
}

model User {
  id           String @id @default(cuid())
  email        String @unique
  passwordHash String

  name      String?
  firstName String?
  lastName  String?
  birthDate DateTime?
  gender    String?
  phone     String?

  company        String?
  companyAddress String?
  companyStreet  String?
  companyZip     String?
  companyCity    String?
  companyCountry String?
  position       String?

  role         Role @default(USER)
  creditsTotal Int  @default(0)

  leaderboardOptIn Boolean @default(false)
  leaderboardName  String?

  creditTxs          CreditTransaction[]
  enrollments        Enrollment[]
  certificates       Certificate[]
  passwordResetTokens PasswordResetToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Training {
  id    String @id @default(cuid())
  title String

  code String?

  date DateTime

  endDate     DateTime?
  location    String?
  instructor  String?
  description String?

  certificateKind CertificateKind?

  cobraId String? @unique

  creditsAward Int @default(0)

  tokens            ClaimToken[]
  creditTxs         CreditTransaction[]
  enrollments       Enrollment[]
  certificates      Certificate[]
  cobraParticipants CobraTrainingParticipant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
  @@index([certificateKind])
}

model Enrollment {
  id         String @id @default(cuid())
  userId     String
  trainingId String

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  training Training @relation(fields: [trainingId], references: [id], onDelete: Cascade)

  status   EnrollmentStatus @default(CONFIRMED)
  attended Boolean          @default(false)
  passed   Boolean          @default(false)

  certificate Certificate?

  registeredAt DateTime @default(now())
  completedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, trainingId])
  @@index([trainingId, status])
  @@index([userId, status])
}

model Certificate {
  id           String @id @default(cuid())
  userId       String
  trainingId   String
  enrollmentId String @unique

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  training   Training   @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  title    String
  issuedAt DateTime          @default(now())
  status   CertificateStatus @default(ISSUED)
  credits  Int               @default(0)

  code            String?
  certificateKind CertificateKind?

  pdfUrl String?
  note   String?

  creditTx CreditTransaction?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, issuedAt])
  @@index([trainingId, issuedAt])
  @@index([code])
  @@index([certificateKind])
}

model ClaimToken {
  id         String   @id @default(cuid())
  token      String   @unique
  trainingId String
  training   Training @relation(fields: [trainingId], references: [id], onDelete: Cascade)

  expiresAt DateTime
  maxClaims Int @default(999999)
  claims    Int @default(0)

  creditTxs CreditTransaction[]

  createdAt DateTime @default(now())
}

model CreditTransaction {
  id     String @id @default(cuid())
  userId String
  amount Int
  type   CreditTxType
  reason CreditTxReason

  trainingId    String?
  certificateId String? @unique
  claimTokenId  String?

  meta Json?

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  training    Training?    @relation(fields: [trainingId], references: [id], onDelete: SetNull)
  certificate Certificate? @relation(fields: [certificateId], references: [id], onDelete: SetNull)
  claimToken  ClaimToken?  @relation(fields: [claimTokenId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([trainingId, createdAt])
  @@index([claimTokenId, createdAt])
  @@index([certificateId, createdAt])
}

model CobraTrainingParticipant {
  id String @id @default(cuid())

  cobraParticipantId String @unique

  cobraTrainingCaption String?
  cobraTrainingId      String?

  trainingId String?
  training   Training? @relation(fields: [trainingId], references: [id], onDelete: SetNull)

  caption         String?
  participantText String
  participantType String?
  status          String?

  email     String?
  firstName String?
  lastName  String?
  company   String?

  raw Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([cobraTrainingId])
  @@index([trainingId])
  @@index([email])
  @@index([participantType])
  @@index([status])
}