generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum CreditTxType {
  AWARD       // Vergabe von Credits
  ADJUSTMENT  // Admin-Korrektur (+/-)
}

enum Role {
  USER
  ADMIN
}

enum CreditTxReason {
  TRAINING_CLAIM
  ADMIN_ADJUST
  CERTIFICATE_ISSUED
}

enum EnrollmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  ATTENDED
  NO_SHOW
  COMPLETED
  CERTIFICATE_ISSUED
}

enum CertificateStatus {
  ISSUED
  REVOKED
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String?
  birthDate    DateTime?

  company        String?
  gender         String?
  companyAddress String?

  role         Role @default(USER)
  creditsTotal Int  @default(0)

  badges        Badge[]
  creditTxs     CreditTransaction[]
  enrollments   Enrollment[]
  certificates  Certificate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Training {
  id    String @id @default(cuid())
  title String

  // Bisheriges Datumsfeld
  date DateTime

  // Neue optionale Detailfelder für spätere Cobra-Daten
  endDate     DateTime?
  location    String?
  instructor  String?
  description String?

  // Optionaler späterer Cobra-Bezug
  cobraId String? @unique

  creditsAward Int @default(0)

  tokens       ClaimToken[]
  badges       Badge[]
  creditTxs    CreditTransaction[]
  enrollments  Enrollment[]
  certificates Certificate[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Enrollment {
  id         String @id @default(cuid())
  userId     String
  trainingId String

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  training Training @relation(fields: [trainingId], references: [id], onDelete: Cascade)

  status   EnrollmentStatus @default(CONFIRMED)
  attended Boolean          @default(false)
  passed   Boolean          @default(false)

  certificate Certificate?

  registeredAt DateTime @default(now())
  completedAt  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, trainingId])
  @@index([trainingId, status])
  @@index([userId, status])
}

model Certificate {
  id           String @id @default(cuid())
  userId       String
  trainingId   String
  enrollmentId String @unique

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  training   Training   @relation(fields: [trainingId], references: [id], onDelete: Cascade)
  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  title      String
  issuedAt   DateTime          @default(now())
  status     CertificateStatus @default(ISSUED)
  credits    Int               @default(0)

  pdfUrl String?
  note   String?

  creditTx CreditTransaction?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, issuedAt])
  @@index([trainingId, issuedAt])
}

model ClaimToken {
  id         String   @id @default(cuid())
  token      String   @unique
  trainingId String
  training   Training @relation(fields: [trainingId], references: [id], onDelete: Cascade)

  expiresAt DateTime
  maxClaims Int @default(999999)
  claims    Int @default(0)

  creditTxs CreditTransaction[]

  createdAt DateTime @default(now())
}

model Badge {
  id         String @id @default(cuid())
  userId     String
  trainingId String

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  training Training @relation(fields: [trainingId], references: [id], onDelete: Cascade)

  issuedAt DateTime @default(now())

  // Legacy / Übergang: bisherige Zertifikats- oder Badge-Logik
  issuedById String?
  note       String?

  creditTx CreditTransaction?

  @@unique([userId, trainingId])
}

model CreditTransaction {
  id     String @id @default(cuid())
  userId String
  amount Int
  type   CreditTxType
  reason CreditTxReason

  trainingId    String?
  badgeId       String? @unique
  certificateId String? @unique
  claimTokenId  String?

  meta Json?

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  training    Training?    @relation(fields: [trainingId], references: [id], onDelete: SetNull)
  badge       Badge?       @relation(fields: [badgeId], references: [id], onDelete: SetNull)
  certificate Certificate? @relation(fields: [certificateId], references: [id], onDelete: SetNull)
  claimToken  ClaimToken?  @relation(fields: [claimTokenId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([trainingId, createdAt])
  @@index([claimTokenId, createdAt])
  @@index([certificateId, createdAt])
}